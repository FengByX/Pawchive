<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground">

    <!-- Header area -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/header_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/colorSurface"
        android:padding="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@android:drawable/ic_menu_revert"
            android:contentDescription="@string/back"
            app:tint="?attr/colorOnSurface"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <TextView
            android:id="@+id/tv_header_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:textColor="?attr/colorOnSurface"
            android:textSize="18sp"
            android:textStyle="bold"
            android:text="@string/post_details"
            app:layout_constraintEnd_toStartOf="@+id/btn_post_bookmark"
            app:layout_constraintStart_toEndOf="@+id/btn_back"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <ImageView
            android:id="@+id/btn_post_bookmark"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@android:drawable/btn_star_big_off"
            android:contentDescription="@string/bookmark_description"
            app:tint="?attr/colorOnSurface"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Fixed video player area (B站置顶风格) -->
    <LinearLayout
        android:id="@+id/video_player_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone"
        android:background="?attr/colorSurface"
        app:layout_constraintTop_toBottomOf="@+id/header_layout">

        <!-- Video display area -->
        <FrameLayout
            android:id="@+id/video_display_frame"
            android:layout_width="match_parent"
            android:layout_height="240dp"
            android:background="@android:color/black">

            <androidx.media3.ui.PlayerView
                android:id="@+id/player_view"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:show_buffering="always"
                app:resize_mode="fit"
                app:use_controller="false" />

            <ProgressBar
                android:id="@+id/video_loading_progress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:indeterminateTint="@android:color/white" />

            <ImageButton
                android:id="@+id/video_play_button"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_play_circle"
                android:background="@drawable/circle_background"
                app:tint="@android:color/white"
                android:visibility="gone"
                android:contentDescription="@string/play_video" />

        </FrameLayout>

        <!-- Custom Media controller bar -->
        <LinearLayout
            android:id="@+id/video_controller_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="8dp"
            android:gravity="center_vertical"
            android:background="?attr/colorSurfaceVariant">

            <ImageButton
                android:id="@+id/btn_play_pause"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_play"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="?attr/colorOnSurface"
                android:contentDescription="@string/play" />

            <TextView
                android:id="@+id/tv_current_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00:00"
                android:textColor="?attr/colorOnSurface"
                android:textSize="13sp"
                android:layout_marginStart="8dp" />

            <SeekBar
                android:id="@+id/seekbar_video"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"
                android:thumbTint="?attr/colorPrimary"
                android:progressTint="?attr/colorPrimary"
                android:progressBackgroundTint="?attr/colorOnSurfaceVariant" />

            <TextView
                android:id="@+id/tv_duration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00:00"
                android:textColor="?attr/colorOnSurface"
                android:textSize="13sp" />

            <!-- Speed button -->
            <ImageButton
                android:id="@+id/btn_speed"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_speed"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="?attr/colorOnSurface"
                android:contentDescription="@string/speed" />

            <!-- Cast button -->
            <ImageButton
                android:id="@+id/btn_cast"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_cast"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="?attr/colorOnSurface"
                android:contentDescription="@string/cast" />

            <!-- Download button -->
            <ImageButton
                android:id="@+id/btn_download"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_download"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="?attr/colorOnSurface"
                android:contentDescription="@string/download" />

            <!-- Fullscreen button -->
            <ImageButton
                android:id="@+id/btn_fullscreen"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_fullscreen"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="?attr/colorOnSurface"
                android:contentDescription="@string/fullscreen" />

            <!-- Close button -->
            <ImageButton
                android:id="@+id/btn_close_video"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginStart="8dp"
                android:src="@drawable/ic_close"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="?attr/colorOnSurface"
                android:contentDescription="@string/close" />

        </LinearLayout>

        <!-- Video info bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="8dp"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tv_video_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="13sp"
                android:text="video.mp4" />

            <TextView
                android:id="@+id/tv_video_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="?attr/colorTextMuted"
                android:textSize="12sp"
                android:text="1/3" />

        </LinearLayout>

    </LinearLayout>

    <!-- Scrollable content -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/nestedScrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/video_player_container">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Title -->
            <TextView
                android:id="@+id/tv_post_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="?attr/colorOnSurface"
                android:textSize="22sp"
                android:textStyle="bold"
                android:text="Post Title" />

            <!-- Service, Creator, Date Info -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_post_service"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="8dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="?attr/colorPrimaryContainer">

                    <TextView
                        android:id="@+id/tv_post_service"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingHorizontal="6dp"
                        android:paddingVertical="2dp"
                        android:textColor="?attr/colorOnPrimaryContainer"
                        android:textSize="11sp"
                        android:text="fanbox" />
                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:id="@+id/tv_post_creator"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:textColor="?attr/colorPrimary"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:text="Creator" />

                <TextView
                    android:id="@+id/tv_post_date"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:textColor="?attr/colorTextMuted"
                    android:textSize="12sp"
                    android:text="Date" />

            </LinearLayout>

            <!-- Main Post Image -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/image_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:visibility="gone"
                app:cardCornerRadius="12dp"
                app:cardBackgroundColor="?attr/colorSurface"
                app:strokeWidth="1dp"
                app:strokeColor="?attr/colorOutlineVariant">

                <ImageView
                    android:id="@+id/iv_post_image"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:adjustViewBounds="true"
                    android:scaleType="fitCenter"
                    android:maxHeight="360dp" />

            </com.google.android.material.card.MaterialCardView>

            <!-- Content HTML / Text -->
            <TextView
                android:id="@+id/tv_post_content"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:textColor="?attr/colorOnSurface"
                android:textSize="15sp"
                android:lineSpacingMultiplier="1.2"
                android:text="Post content goes here..."
                android:textIsSelectable="true"
                android:linksClickable="true" />

            <!-- Attachments Divider / Header -->
            <TextView
                android:id="@+id/tv_attachments_header"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:textColor="?attr/colorPrimary"
                android:textSize="16sp"
                android:textStyle="bold"
                android:text="@string/attachments"
                android:visibility="gone" />

            <!-- Attachments container -->
            <LinearLayout
                android:id="@+id/layout_attachments"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="8dp" />

            <!-- Revisions Section -->
            <TextView
                android:id="@+id/tv_revisions_header"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:textColor="?attr/colorPrimary"
                android:textSize="16sp"
                android:textStyle="bold"
                android:text="@string/revisions"
                android:visibility="gone" />

            <LinearLayout
                android:id="@+id/layout_revisions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="8dp" />

            <!-- Comments Divider / Header -->
            <TextView
                android:id="@+id/tv_comments_header"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:textColor="?attr/colorSecondary"
                android:textSize="16sp"
                android:textStyle="bold"
                android:text="@string/comments"
                android:visibility="gone" />

            <!-- Comments RecyclerView -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_comments"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:nestedScrollingEnabled="false" />

            <!-- Navigation buttons: Prev / Next -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="16dp"
                android:gravity="center">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_prev_post"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:text="@string/previous"
                    android:visibility="gone"
                    app:cornerRadius="12dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_next_post"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:text="@string/next"
                    android:visibility="gone"
                    app:cornerRadius="12dp" />

            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
