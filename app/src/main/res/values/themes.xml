<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Apple (default) - System Blue #007AFF -->
    <style name="Theme.Pawchive" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">#007AFF</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorPrimaryContainer">#D1E7FF</item>
        <item name="colorOnPrimaryContainer">#001A3D</item>
        <item name="colorSecondary">#34C759</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="colorSecondaryContainer">#D1F5D9</item>
        <item name="colorOnSecondaryContainer">#00220A</item>
        <item name="colorTertiary">#FF9500</item>
        <item name="colorOnTertiary">@color/white</item>
        <item name="colorTertiaryContainer">#FFE0B3</item>
        <item name="colorOnTertiaryContainer">#331A00</item>

        <item name="colorSurface">@color/card_light</item>
        <item name="colorOnSurface">@color/text_primary_light</item>
        <item name="colorSurfaceVariant">@color/bg_light</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary_light</item>
        <item name="colorOutline">@color/divider_light</item>
        <item name="colorOutlineVariant">@color/divider_light</item>

        <item name="android:windowBackground">@color/bg_light</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>

        <!-- Custom app attributes -->
        <item name="colorCardBackground">@color/card_light</item>
        <item name="colorDivider">@color/divider_light</item>
        <item name="colorTextPrimary">@color/text_primary_light</item>
        <item name="colorTextSecondary">@color/text_secondary_light</item>
        <item name="colorTextMuted">@color/text_muted_light</item>
        <item name="colorBadgeBackground">@color/primary</item>
    </style>

