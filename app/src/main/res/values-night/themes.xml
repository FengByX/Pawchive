<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Apple (default) - Dark mode -->
    <style name="Theme.Pawchive" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">#0A84FF</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorPrimaryContainer">#004299</item>
        <item name="colorOnPrimaryContainer">#D1E7FF</item>
        <item name="colorSecondary">#30D158</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="colorSecondaryContainer">#004020</item>
        <item name="colorOnSecondaryContainer">#B8F2C8</item>
        <item name="colorTertiary">#FF9F0A</item>
        <item name="colorOnTertiary">@color/black</item>
        <item name="colorTertiaryContainer">#4D2B00</item>
        <item name="colorOnTertiaryContainer">#FFE0B3</item>

        <item name="colorSurface">@color/card_dark</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorSurfaceVariant">@color/bg_dark</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary</item>
        <item name="colorOutline">@color/divider_dark</item>
        <item name="colorOutlineVariant">@color/divider_dark</item>

        <item name="android:windowBackground">@color/bg_dark</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>

        <!-- Custom app attributes -->
        <item name="colorCardBackground">@color/card_dark</item>
        <item name="colorDivider">@color/divider_dark</item>
        <item name="colorTextPrimary">@color/text_primary</item>
        <item name="colorTextSecondary">@color/text_secondary</item>
        <item name="colorTextMuted">@color/text_muted</item>
        <item name="colorBadgeBackground">@color/primary</item>
    </style>

